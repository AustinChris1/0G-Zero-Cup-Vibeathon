# ----------------------------------------------------------------------------
# Receipts runs out of the box in DEMO mode with zero config.
# Demo mode uses a real ECDSA enclave keypair, so signature verification is
# genuinely real (you cannot alter a sealed pick without breaking its proof).
#
# To flip the runtime brain over to the live 0G stack, fill these in and run:
#   npm i @0glabs/0g-serving-broker @0gfoundation/0g-ts-sdk
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Shared store. REQUIRED on Vercel for writes (create agent, seal pick, resolve)
# to persist and be shared across serverless instances. Create a free Upstash
# Redis database (or Vercel KV, same thing), paste its REST credentials here and
# in your Vercel project settings. The store self-seeds from data/snapshot.json
# on first use. Without these the app uses a local JSON file (fine for local dev;
# on Vercel writes would not persist across instances).
# ----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to "live" to use the real 0G Compute + Storage + Chain.
# Anything else (or unset) keeps the self-contained demo runtime.
OG_MODE=demo

# A funded 0G Galileo testnet private key (for inference fees + storage writes).
# Get test OG from the 0G faucet. Never commit a real key.
OG_PRIVATE_KEY=

# 0G Galileo testnet RPC. Confirm the current chain id from docs.0g.ai.
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Compute inference provider address (a TEE-backed model).
# Example from the starter kit (Gemma 3 27B). List live ones with the broker.
OG_PROVIDER_ADDRESS=0x69Eb5a0BD7d0f4bF39eD5CE9Bd3376c61863aE08

# 0G Storage indexer endpoint.
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Optional: deployed Leaderboard contract address for on-chain settlement.
OG_LEADERBOARD_ADDRESS=

# Demo-only: fixed enclave signing key so receipts stay verifiable across
# restarts. If unset, a deterministic dev key is derived at boot.
DEMO_ENCLAVE_KEY=

# ----------------------------------------------------------------------------
# Real World Cup data (hybrid). Optional. The Fixtures "Sync" button pulls real
# fixtures + results. Without a working provider the app stays on the seed.
#
# Providers (set FOOTBALL_PROVIDER):
#   football-data  -> FULL 2026 World Cup on the FREE tier. Free token required:
#                     https://www.football-data.org/client/register
#   thesportsdb    -> no signup; free key "3" caps results to a few matches.
#   api-football   -> full data, but the FREE plan blocks season 2026.
# ----------------------------------------------------------------------------
FOOTBALL_SEASON=2026
FOOTBALL_PROVIDER=football-data

# football-data.org (default)
FOOTBALL_DATA_TOKEN=

# TheSportsDB (no signup; limited free key)
THESPORTSDB_KEY=3
THESPORTSDB_WC_ID=4429

# API-Football (optional alternative)
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_LEAGUE=1
